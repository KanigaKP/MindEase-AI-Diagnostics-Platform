# MindEase Backend Environment Configuration Example
# Copy this file to .env and fill in your details

# Groq API Key for LLM Inference (Get one at console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_placeholder

# Security Settings
JWT_SECRET=mindease-neon-cyber-secret-hash-1337-replace-in-production
ADMIN_TOKEN=mindease-admin-bypass-key

# Vector Database (ChromaDB) Configuration
# When running via Docker, host should be 'chroma'
# When running locally via python, host should be 'localhost'
CHROMA_HOST=localhost
CHROMA_PORT=8001
